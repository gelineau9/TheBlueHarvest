{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".next/**", "!.next/cache/**"],
      "env": ["NODE_ENV", "BACKEND_", "BACKEND_INTERNAL_*", "DB_*", "POSTGRES_*", "JWT_SECRET"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "start": {
      "dependsOn": ["build"],
      "cache": false
    },
    "lint": {
      "dependsOn": ["^lint"],
      "outputs": []
    },

    "check-types": {
      "dependsOn": ["^check-types"],
      "outputs": []
    },

    "test": {
      "cache": false,
      "env": [
        "NODE_ENV",
        "DB_HOST",
        "DB_PORT",
        "DB_USER",
        "DB_PASSWORD",
        "DB_NAME",
        "DB_SSLMODE",
        "DATABASE_URL",
        "JWT_SECRET"
      ]
    }
  }
}
