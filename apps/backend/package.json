{
  "name": "blue-harvest-backend",
  "version": "0.1.0",
  "private": true,
  "description": "Backend for TheBlueHarvest",
  "homepage": "https://github.com/gelineau9/TheBlueHarvest#readme",
  "bugs": {
    "url": "https://github.com/gelineau9/TheBlueHarvest/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gelineau9/TheBlueHarvest.git"
  },
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "start": "node dist/index.js",
    "dev": "nodemon --signal SIGTERM --exec tsx src/index.ts",
    "dev:local": "nodemon --signal SIGTERM --exec tsx --env-file=../../.env src/index.ts",
    "migrate": "npx node-pg-migrate --migrations-dir ../../db/migrations --migrations-table schema_migrations up",
    "lint": "eslint src --ext .js,.jsx,.ts,.tsx",
    "lint:fix": "eslint src/**/*.{ts,js} --fix",
    "check-types": "tsc --noEmit",
    "test": "npx vitest run",
    "test:ui": "npx vitest --ui",
    "test:watch": "npx vitest"
  },
  "dependencies": {
    "@slonik/pg-driver": "^48.10.3",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.0.0",
    "argon2": "^0.44.0",
    "config": "^4.1.1",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "express-rate-limit": "^8.2.1",
    "file-type": "^21.0.0",
    "express-validator": "^7.3.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.0.2",
    "pg": "^8.20.0",
    "sharp": "^0.34.5",
    "slonik": "^48.8.7",
    "resend": "^4.0.0",
    "winston": "^3.19.0",
    "yn": "^5.1.0"
  },
  "devDependencies": {
    "@types/pg": "^8.20.0",
    "@types/sharp": "^0.31.1",
    "@types/supertest": "^6.0.3",
    "@typescript-eslint/eslint-plugin": "^8.20.0",
    "@typescript-eslint/parser": "^8.20.0",
    "@vitest/coverage-v8": "^4.1.1",
    "@vitest/ui": "^4.0.18",
    "eslint": "^9.39.2",
    "node-pg-migrate": "^8.0.4",
    "nodemon": "^3.1.11",
    "supertest": "^7.2.2",
    "tsx": "^4.21.0",
    "typescript-eslint": "^8.20.0",
    "vitest": "^4.0.18"
  }
}
