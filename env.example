# =============================================================
# TheBlueHarvest — Environment Variables
#
# Copy this file to .env and fill in real values before running.
# NEVER commit .env to version control.
#
# Generate a strong JWT secret:
#   openssl rand -base64 48
# =============================================================

# Runtime environment
NODE_ENV=development

# ─────────────────────────────────────────
# PostgreSQL (Docker service + Slonik)
# ─────────────────────────────────────────

# Used by the postgres Docker image to create the database on first init.
# DB_USER / DB_PASSWORD must match these values.
POSTGRES_USER=merry
POSTGRES_PASSWORD=secondbreakfast
POSTGRES_DB=bha_db

# Used by the backend (Slonik connection string)
DB_HOST=postgres
DB_USER=merry
DB_PASSWORD=secondbreakfast
DB_NAME=bha_db
DB_PORT=5432
# disable  — local Docker Postgres (no SSL)
# no-verify — Supabase / hosted Postgres
DB_SSLMODE=disable

# Used by node-pg-migrate when running migrations.
# Must match the DB_* values above.
# Local dev (host machine, Postgres exposed on 5433): postgres://merry:secondbreakfast@localhost:5433/bha_db
# Docker migration service (inside Docker network):   postgres://merry:secondbreakfast@postgres:5432/bha_db
DATABASE_URL=postgres://merry:secondbreakfast@localhost:5433/bha_db

# ─────────────────────────────────────────
# Auth
# ─────────────────────────────────────────

# REQUIRED — must be at least 32 characters.
# Production: generate with `openssl rand -base64 48`
JWT_SECRET=yourjwtsecret

# ─────────────────────────────────────────
# Backend server
# ─────────────────────────────────────────

BACKEND_PORT=4000

# Public-facing base URL for uploaded file URLs returned in API responses.
# Development: http://localhost:4000
# Production:  https://yourdomain.com  (no trailing slash)
BACKEND_URL=http://localhost:4000

# Comma-separated list of origins allowed to make CORS requests to the backend.
# Development: http://localhost:3000
# Production:  https://yourdomain.com
ALLOWED_ORIGINS=http://localhost:3000

# ─────────────────────────────────────────
# Frontend (Next.js)
# ─────────────────────────────────────────

# Internal URL the Next.js server uses to reach the backend (server-to-server).
# Docker: http://backend:4000  |  Local dev: http://localhost:4000
BACKEND_INTERNAL_URL=http://backend:4000

# Public-facing backend hostname — baked into the Next.js JS bundle at build time.
# Used in next.config.ts to whitelist the image remote pattern.
# Do NOT include the protocol (https://) — hostname only.
# Development: localhost
# Production:  yourdomain.com
NEXT_PUBLIC_BACKEND_HOSTNAME=localhost
